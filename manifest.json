{
  "manifest_version": 3,
  "name": "Highfine",
  "version": "1.0.0",
  "description": "Highlights selected text and shows a popup",

  "browser_specific_settings": {
    "gecko": {
      "id": "your-extension@yourdomain.com"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],

  "permissions": [
    "storage"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icons-48.png"
  },

  "icons": {
    "32": "icons/icons-32.png",
    "48": "icons/icons-48.png"
  },

  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js",
    "type": "module"
  }
}
